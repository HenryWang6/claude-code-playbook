{
  "hooks": {
    "Stop": [
      {
        "hooks": [{
          "type": "command",
          "command": "afplay /System/Library/Sounds/Glass.aiff"
        }]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [{
          "type": "command",
          "command": "afplay /System/Library/Sounds/Basso.aiff"
        }]
      }
    ]
  }
}
